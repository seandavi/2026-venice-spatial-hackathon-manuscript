# Quarto build artifacts
_output/
_freeze/
.quarto/
*_files/
*_cache/
**/*.quarto_ipynb

# Quarto format-resources are copied to the project root during render
# (kept under _extensions/<name>/ as the source of truth).
/plos2015.bst

# Rendered outputs anywhere in the tree (commit only when explicitly intended)
**/*.html
**/*.pdf
**/*.docx
**/*.tex
**/*.aux
**/*.log
**/*.out
**/*.toc

# Some figures and references are legit PDFs/HTML downloads — these are
# tracked explicitly even though they match the patterns above. Use:
#   git add -f path/to/file.pdf
# to override the ignore rule when adding a real artifact.

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Local env
.Renviron
.Rhistory
.RData
.Rproj.user/
# Exception: the version banner is checked-in HTML source, not render output
!_version-banner.html
!_version-banner.html.template

# Exception: Quarto extension assets (templates, BibTeX styles, partials)
# are source files that ship with the extension, not render artifacts.
!_extensions/**

/.quarto/
